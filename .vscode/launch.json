{
   "version":"0.2.0",
   "configurations":[
      {
         "name":"Python: Debug main.py (local)",
         "type":"debugpy",
         "request":"launch",
         "program":"${workspaceFolder}/main.py",
         //"console":"integratedTerminal",
         "console":"internalConsole",
         "cwd":"${workspaceFolder}",
         "justMyCode":false,
         "env":{
            "PYTHONUNBUFFERED":"1",
            "CUDA_VISIBLE_DEVICES":"-1",
            "TF_CPP_MIN_LOG_LEVEL":"2",
            "TF_ENABLE_ONEDNN_OPTS":"0",
            "TZ":"America/Sao_Paulo"
         }
      },
      {
         "name":"Python: Debug Uvicorn (local)",
         "type":"debugpy",
         "request":"launch",
         "module":"uvicorn",
         "args":[
            "main:app",
            "--host",
            "0.0.0.0",
            "--port",
            "8000",
            "--reload"
         ],
         "console":"integratedTerminal",
         "cwd":"${workspaceFolder}",
         "justMyCode":false,
         "env":{
            "PYTHONUNBUFFERED":"1",
            "CUDA_VISIBLE_DEVICES":"-1",
            "TF_CPP_MIN_LOG_LEVEL":"2",
            "TF_ENABLE_ONEDNN_OPTS":"0",
            "TZ":"America/Sao_Paulo"
         }
      },
      {
         "name":"Python: Attach no container Docker",
         "type":"debugpy",
         "request":"attach",
         "connect":{
            "host":"localhost",
            "port":5678
         },
         "pathMappings":[
            {
               "localRoot":"${workspaceFolder}",
               "remoteRoot":"/app"
            }
         ],
         "justMyCode":false
      }
   ]
}